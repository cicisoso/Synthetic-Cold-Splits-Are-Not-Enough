\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Synthetic reference panel and primary temporal/provenance benchmarks for the five-model comparison panel. Values are mean $\pm $ std over seeds. Best mean AUPRC{} in each row is bold. \texttt  {RF} is a Random Forest baseline trained on the same Morgan+k-mer descriptor set as \texttt  {base}, and \texttt  {GraphDTA-style} is the graph-based baseline. The \texttt  {GraphDTA-style} entry for \texttt  {blind\_start} is left blank because only a seed0 screening run was available when the matched graph-based follow-up panel was frozen; to avoid mixing one-seed screens with three-seed rows, that screening value is not combined into the main table. The row-wise interpretation of the top-ranked model is discussed in the surrounding text rather than repeated as separate table columns.}}{9}{table.2}\protected@file@percent }
\newlabel{tab:main-results}{{2}{9}{Synthetic reference panel and primary temporal/provenance benchmarks for the five-model comparison panel. Values are mean $\pm $ std over seeds. Best mean \AUPRC {} in each row is bold. \texttt {RF} is a Random Forest baseline trained on the same Morgan+k-mer descriptor set as \texttt {base}, and \texttt {GraphDTA-style} is the graph-based baseline. The \texttt {GraphDTA-style} entry for \texttt {blind\_start} is left blank because only a seed0 screening run was available when the matched graph-based follow-up panel was frozen; to avoid mixing one-seed screens with three-seed rows, that screening value is not combined into the main table. The row-wise interpretation of the top-ranked model is discussed in the surrounding text rather than repeated as separate table columns}{table.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Primary temporal/provenance benchmarks alter the ranking again}{9}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Mean within-benchmark AUPRC{} delta relative to \texttt  {base} for the five-model comparison panel. Bars are shown for the compared systems with paired-bootstrap support currently available. Because prevalence differs across benchmarks, the vertical scale should be read as a row-wise within-benchmark contrast rather than as a cross-benchmark effect-size scale}}{11}{figure.1}\protected@file@percent }
\newlabel{fig:delta-summary}{{1}{11}{Mean within-benchmark \AUPRC {} delta relative to \texttt {base} for the five-model comparison panel. Bars are shown for the compared systems with paired-bootstrap support currently available. Because prevalence differs across benchmarks, the vertical scale should be read as a row-wise within-benchmark contrast rather than as a cross-benchmark effect-size scale}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Temporal shift is structured across year bands and overlap levels}{11}{subsection.4.3}\protected@file@percent }
